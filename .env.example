# ── OpenAI ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# After fine-tuning, swap this to your fine-tuned model ID:
# OPENAI_CHAT_MODEL=ft:gpt-4o-mini-2024-07-18:org:unified-rag:abc123

# ── Vector DB ────────────────────────────────────────────────
VECTOR_DB=chroma                     # chroma | pinecone
CHROMA_PERSIST_DIR=./data/chroma_db
PINECONE_API_KEY=
PINECONE_INDEX_NAME=unified-rag

# ── Neo4j Knowledge Graph ─────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ── Re-ranking ────────────────────────────────────────────────
COHERE_API_KEY=                      # optional — falls back to CrossEncoder
RERANKER_BACKEND=cross_encoder       # cross_encoder | cohere | none

# ── Memory ───────────────────────────────────────────────────
DEFAULT_MEMORY_STRATEGY=buffer       # buffer | summary | vector
BUFFER_WINDOW_SIZE=10
SUMMARY_MAX_TOKENS=2000

# ── API ──────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change-me-in-production

# ── Observability (optional) ──────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=unified-rag

